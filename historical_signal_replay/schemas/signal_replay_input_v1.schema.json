{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://safe-fast.local/schemas/signal_replay_input_v1.schema.json",
  "title": "SAFE-FAST Historical Signal Replay Input v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "symbol",
    "timestamp",
    "candles_1h_rth",
    "context_24h_daily",
    "market_calendar_session",
    "macro_context",
    "iv_context",
    "event_context"
  ],
  "properties": {
    "symbol": {
      "type": "string",
      "enum": ["SPY", "QQQ", "IWM", "GLD"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "candles_1h_rth": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["timestamp", "open", "high", "low", "close", "volume"],
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "open": {
            "type": "number"
          },
          "high": {
            "type": "number"
          },
          "low": {
            "type": "number"
          },
          "close": {
            "type": "number"
          },
          "volume": {
            "type": "number",
            "minimum": 0
          }
        }
      }
    },
    "context_24h_daily": {
      "$ref": "#/$defs/contextValue"
    },
    "market_calendar_session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_date", "session_type", "is_regular_session", "timezone"],
      "properties": {
        "session_date": {
          "type": "string",
          "format": "date"
        },
        "session_type": {
          "type": "string",
          "enum": ["regular", "short", "closed", "unknown"]
        },
        "is_regular_session": {
          "type": "boolean"
        },
        "timezone": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "macro_context": {
      "$ref": "#/$defs/contextValue"
    },
    "iv_context": {
      "$ref": "#/$defs/contextValue"
    },
    "event_context": {
      "$ref": "#/$defs/contextValue"
    }
  },
  "$defs": {
    "contextValue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "value"],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "CONFIRMED",
            "CONTEXT_24H_DAILY_UNCONFIRMED",
            "MACRO_UNCONFIRMED",
            "IV_UNCONFIRMED",
            "EVENT_UNCONFIRMED",
            "UNCONFIRMED"
          ]
        },
        "value": {
          "type": ["string", "number", "boolean", "object", "array", "null"]
        },
        "as_of": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "source": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
